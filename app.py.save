@app.route('/health', methods=['GET'])
def health_check():
    """Endpoint sprawdzania stanu aplikacji"""
    return jsonify({
        'status': 'healthy',
        'timestamp': datetime.now().isoformat(),
        'database': 'connected' if os.path.exists(DATABASE_PATH) else 'missing',
        'admin_panel': 'available'
    }), 200

@app.errorhandler(404)
def not_found(error):
    return jsonify({'error': 'Endpoint not found'}), 404

@app.errorhandler(405)
def method_not_allowed(error):
    return jsonify({'error': 'Method not allowed'}), 405

if __name__ == '__main__':
    # Inicjalizuj bazę danych przy starcie
    init_database()
    
    logging.info("ESP32-C3 Water System VPS Logger started")
    logging.info(f"Database: {DATABASE_PATH}")
    logging.info(f"Log file: {LOG_PATH}")
    logging.info("Admin panel available at: /admin")
    
    # Uruchom aplikację
    app.run(host='0.0.0.0', port=5000, debug=False)
